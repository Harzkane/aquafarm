# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aquafarm?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=generate-a-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_NAME=AquaFarm
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=2348012345678
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hello AquaFarm team, I need help choosing a plan.
NEXT_PUBLIC_COMMUNITY_SUPPORT_URL=https://chat.whatsapp.com/replace-with-your-community-link
NEXT_PUBLIC_WHATSAPP_PRIORITY_NUMBER=2348012345678
NEXT_PUBLIC_WHATSAPP_PRIORITY_MESSAGE_PRO=Hello AquaFarm team, I need priority support for my Pro Founder account.
NEXT_PUBLIC_WHATSAPP_PRIORITY_MESSAGE_COMMERCIAL=Hello AquaFarm team, I need priority support for my Pro+ Commercial account.
NEXT_PUBLIC_COMMERCIAL_ONBOARDING_URL=https://calendly.com/your-team/commercial-onboarding
NEXT_PUBLIC_COMMERCIAL_CHECKIN_URL=https://calendly.com/your-team/commercial-monthly-checkin

# Billing (Paystack)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=sk_test_xxx
PAYSTACK_PRO_AMOUNT_KOBO=500000
PAYSTACK_COMMERCIAL_AMOUNT_KOBO=1500000

# Redis rate limiting (Upstash REST for Vercel/Edge middleware)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Internal cron protection
# Used by:
# - /api/internal/cron/billing-reconcile
# - /api/internal/cron/billing-events-prune
# - /api/internal/cron/alerts-evaluate
# - /api/internal/cron/alerts-dispatch
CRON_SECRET=generate-a-long-random-secret

# Outbound alert delivery (WhatsApp via webhook adapter)
# Example: your own relay endpoint that calls WhatsApp provider APIs.
ALERT_WHATSAPP_WEBHOOK_URL=https://your-alert-relay.example.com/whatsapp
ALERT_WHATSAPP_WEBHOOK_TOKEN=your-relay-token
ALERTS_WHATSAPP_TO=2348012345678
# Prevent repeated sends for same unresolved alert
ALERT_OUTBOUND_COOLDOWN_MINUTES=360
