{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "tests/phase2/**/*.ts",
    "lib/billing-reconcile.ts",
    "lib/cron-utils.ts",
    "lib/validators/**/*.ts"
  ]
}
